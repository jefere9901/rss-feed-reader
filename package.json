{
  "name": "rss-feed-reader",
  "version": "1.0.1",
  "description": "RSS 订阅阅读器 - 快捷便利的思源笔记插件",
  "scripts": {
    "dev": "vite build --watch",
    "dev:auto": "powershell -File dev-watch.ps1",
    "build": "vite build && node scripts/copy-dist.mjs",
    "pack": "npm run build && node scripts/pack.mjs",
    "deploy": "node scripts/deploy.mjs",
    "build:deploy": "npm run build && npm run deploy",
    "test": "node siyuan-test.mjs",
    "reload": "node scripts/reload.mjs",
    "start": "node dev-watch.mjs"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "siyuan": "^1.0.0",
    "xmldom": "^0.6.0"
  }
}
